\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{scikgtex-pdflatex}[2026/05/28 Minimal SciKG-like metadata annotations for pdfLaTeX]

\RequirePackage{hyperref}
\RequirePackage{hyperxmp}
\RequirePackage{keyval}

\makeatletter

% ============================================================
% Document metadata
% ============================================================

\def\scikg@title{}
\def\scikg@author{}
\def\scikg@keywords{}
\def\scikg@doi{}
\def\scikg@license{}
\newif\ifscikg@anchors
\scikg@anchorsfalse

\define@key{scikgsetup}{title}{\def\scikg@title{#1}}
\define@key{scikgsetup}{author}{\def\scikg@author{#1}}
\define@key{scikgsetup}{keywords}{\def\scikg@keywords{#1}}
\define@key{scikgsetup}{doi}{\def\scikg@doi{#1}}
\define@key{scikgsetup}{license}{\def\scikg@license{#1}}
\define@key{scikgsetup}{anchors}[true]{%
  \edef\scikg@tmp{#1}%
  \def\scikg@true{true}%
  \ifx\scikg@tmp\scikg@true
    \scikg@anchorstrue
  \else
    \scikg@anchorsfalse
  \fi
}

\newcommand{\scikgsetup}[1]{%
  \setkeys{scikgsetup}{#1}%
}

\AtBeginDocument{%
  \hypersetup{%
    pdftitle={\scikg@title},
    pdfauthor={\scikg@author},
    pdfkeywords={\scikg@keywords},
    pdfsubject={DOI: \scikg@doi. License: \scikg@license}%
  }%
}

% ============================================================
% Output file
% ============================================================

\newwrite\scikg@out

\AtBeginDocument{%
  \immediate\openout\scikg@out=\jobname.scikg.jsonl
}

\AtEndDocument{%
  \immediate\closeout\scikg@out
}

% ============================================================
% Annotation state
% ============================================================

\newif\ifscikg@inline
\newif\ifscikg@haslabel

\def\scikg@ann@type{}
\def\scikg@ann@id{}
\def\scikg@ann@label{}
\def\scikg@ann@text{}
\newcount\scikg@anncount
\scikg@anncount=0

\newcommand{\scikg@resetann}{%
  \scikg@inlinetrue
  \scikg@haslabelfalse
  \def\scikg@ann@type{}%
  \def\scikg@ann@id{}%
  \def\scikg@ann@label{}%
  \def\scikg@ann@text{}%
}

\define@key{scikgann}{mode}[inline]{%
  \edef\scikg@tmp{#1}%
  \def\scikg@silent{silent}%
  \ifx\scikg@tmp\scikg@silent
    \scikg@inlinefalse
  \else
    \scikg@inlinetrue
  \fi
}
\define@key{scikgann}{type}{\def\scikg@ann@type{#1}}
\define@key{scikgann}{id}{\def\scikg@ann@id{#1}}
\define@key{scikgann}{label}{%
  \def\scikg@ann@label{#1}%
  \scikg@haslabeltrue
}

% ============================================================
% Invisible anchor for inline annotations
% ============================================================

\newcommand{\scikg@maybeanchor}{%
  \ifscikg@anchors
    \Hy@raisedlink{%
      \hyper@anchorstart{scikg.\the\scikg@anncount}\hyper@anchorend
    }%
  \fi
}

% ============================================================
% Internal writer
% ============================================================

\newcommand{\scikg@writeannotation}{%
  \begingroup
    \edef\scikg@modevalue{%
      \ifscikg@inline inline\else silent\fi
    }%
    \edef\scikg@labelvalue{%
      \ifscikg@haslabel \scikg@ann@label\else \empty\fi
    }%
    \edef\scikg@line{%
      {"n":"\the\scikg@anncount","mode":"\scikg@modevalue","type":"\scikg@ann@type","id":"\scikg@ann@id","label":"\scikg@labelvalue","text":"\scikg@ann@text","page":"\thepage"}%
    }%
    \immediate\write\scikg@out{\scikg@line}%
  \endgroup
}

% ============================================================
% Public command
% ============================================================

\newcommand{\scikgannotate}[2][]{%
  \scikg@resetann
  \setkeys{scikgann}{#1}%
  \def\scikg@ann@text{#2}%
  \global\advance\scikg@anncount by 1\relax
  \ifscikg@inline
    \scikg@maybeanchor
    \scikg@ann@text
  \fi
  \scikg@writeannotation
}

% ============================================================
% Convenience wrappers
% ============================================================

\newcommand{\scikgsoftware}[2]{%
  \scikgannotate[mode=inline,type=software,id={#1}]{#2}%
}
\newcommand{\scikgsoftwaresilent}[2]{%
  \scikgannotate[mode=silent,type=software,id={#1}]{#2}%
}

\newcommand{\scikgperson}[2]{%
  \scikgannotate[mode=inline,type=person,id={#1}]{#2}%
}
\newcommand{\scikgpersonsilent}[2]{%
  \scikgannotate[mode=silent,type=person,id={#1}]{#2}%
}

\newcommand{\scikgdataset}[2]{%
  \scikgannotate[mode=inline,type=dataset,id={#1}]{#2}%
}
\newcommand{\scikgdatasetsilent}[2]{%
  \scikgannotate[mode=silent,type=dataset,id={#1}]{#2}%
}

\newcommand{\scikgmethod}[2]{%
  \scikgannotate[mode=inline,type=method,id={#1}]{#2}%
}
\newcommand{\scikgmethodsilent}[2]{%
  \scikgannotate[mode=silent,type=method,id={#1}]{#2}%
}

\makeatother
\endinput