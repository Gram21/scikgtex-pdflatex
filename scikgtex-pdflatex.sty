\NeedsTeXFormat{LaTeX2e}
\ProvidesExplPackage
  {scikgtex-pdflatex}
  {2026/05/28}
  {0.8}
  {Minimal SciKG-like metadata annotations for pdfLaTeX}

\RequirePackage{hyperref}
\RequirePackage{hyperxmp}
\RequirePackage{xparse}

\ExplSyntaxOn

% ============================================================
% Global configuration
% ============================================================

\tl_new:N \g_scikg_title_tl
\tl_new:N \g_scikg_author_tl
\tl_new:N \g_scikg_keywords_tl
\tl_new:N \g_scikg_doi_tl
\tl_new:N \g_scikg_license_tl
\tl_new:N \g_scikg_format_tl
\tl_gset:Nn \g_scikg_format_tl { tsv }

\bool_new:N \g_scikg_anchors_bool
\bool_new:N \g_scikg_silentanchors_bool
\bool_new:N \g_scikg_strict_bool

\bool_gset_false:N \g_scikg_anchors_bool
\bool_gset_false:N \g_scikg_silentanchors_bool
\bool_gset_false:N \g_scikg_strict_bool

\iow_new:N \g_scikg_out_iow
\int_new:N \g_scikg_annotation_int

\prop_new:N \g_scikg_label_anchor_prop
\prop_new:N \g_scikg_label_text_prop

% ============================================================
% Local annotation state
% ============================================================

\tl_new:N \l_scikg_mode_tl
\tl_new:N \l_scikg_type_tl
\tl_new:N \l_scikg_id_tl
\tl_new:N \l_scikg_label_tl
\tl_new:N \l_scikg_text_tl
\tl_new:N \l_scikg_anchor_tl
\tl_new:N \l_scikg_page_tl

\bool_new:N \l_scikg_inline_bool
\bool_new:N \l_scikg_has_label_bool

% Sanitized scratch
\tl_new:N \l_scikg_s_anchor_tl
\tl_new:N \l_scikg_s_type_tl
\tl_new:N \l_scikg_s_id_tl
\tl_new:N \l_scikg_s_label_tl
\tl_new:N \l_scikg_s_text_tl
\tl_new:N \l_scikg_s_page_tl

% ============================================================
% Messages
% ============================================================

\msg_new:nnn { scikg } { missing-type }
  { Annotation~#1~is~missing~required~key~`type'. }

\msg_new:nnn { scikg } { missing-id }
  { Annotation~#1~is~missing~required~key~`id'. }

\msg_new:nnn { scikg } { empty-text }
  { Annotation~#1~has~empty~text~argument. }

\msg_new:nnn { scikg } { duplicate-label }
  { Duplicate~annotation~label~`#1'. }

\msg_new:nnn { scikg } { undefined-label }
  { Undefined~annotation~label~`#1'. }

% ============================================================
% Utility
% ============================================================

\prg_new_conditional:Npnn \scikg_if_value_true:n #1 { TF }
  {
    \str_if_eq:eeTF { \tl_trim_spaces:n {#1} } { true }
      { \prg_return_true: }
      { \prg_return_false: }
  }

\cs_new_protected:Npn \scikg_bool_gset_from_string:Nn #1#2
  {
    \scikg_if_value_true:nTF {#2}
      { \bool_gset_true:N #1 }
      { \bool_gset_false:N #1 }
  }

\cs_new_protected:Npn \scikg_warn_or_error:nn #1#2
  {
    \bool_if:NTF \g_scikg_strict_bool
      { \msg_error:nnn   { scikg } {#1} {#2} }
      { \msg_warning:nnn { scikg } {#1} {#2} }
  }

% Conservative stringification.
\cs_new_protected:Npn \scikg_sanitize_to_str:nN #1#2
  {
    \tl_set:Nx #2 { \tl_to_str:n {#1} }
  }

% ============================================================
% Setup keys
% ============================================================

\keys_define:nn { scikg / setup }
  {
    title          .tl_gset:N = \g_scikg_title_tl,
    author         .tl_gset:N = \g_scikg_author_tl,
    keywords       .tl_gset:N = \g_scikg_keywords_tl,
    doi            .tl_gset:N = \g_scikg_doi_tl,
    license        .tl_gset:N = \g_scikg_license_tl,
    format         .tl_gset:N = \g_scikg_format_tl,

    anchors        .code:n    = { \scikg_bool_gset_from_string:Nn \g_scikg_anchors_bool {#1} },
    anchors        .default:n = true,

    silentanchors  .code:n    = { \scikg_bool_gset_from_string:Nn \g_scikg_silentanchors_bool {#1} },
    silentanchors  .default:n = true,

    strict         .code:n    = { \scikg_bool_gset_from_string:Nn \g_scikg_strict_bool {#1} },
    strict         .default:n = true,
  }

\NewDocumentCommand \scikgsetup { m }
  {
    \keys_set:nn { scikg / setup } {#1}
  }

% ============================================================
% Annotation keys
% ============================================================

\keys_define:nn { scikg / ann }
  {
    mode .choice:,
    mode / inline .code:n =
      {
        \tl_set:Nn \l_scikg_mode_tl { inline }
        \bool_set_true:N \l_scikg_inline_bool
      },
    mode / silent .code:n =
      {
        \tl_set:Nn \l_scikg_mode_tl { silent }
        \bool_set_false:N \l_scikg_inline_bool
      },
    mode .initial:n = inline,

    type  .tl_set:N = \l_scikg_type_tl,
    id    .tl_set:N = \l_scikg_id_tl,
    label .code:n   =
      {
        \tl_set:Nn \l_scikg_label_tl {#1}
        \bool_set_true:N \l_scikg_has_label_bool
      },
  }

\cs_new_protected:Npn \scikg_annotation_reset:
  {
    \tl_set:Nn \l_scikg_mode_tl { inline }
    \tl_clear:N \l_scikg_type_tl
    \tl_clear:N \l_scikg_id_tl
    \tl_clear:N \l_scikg_label_tl
    \tl_clear:N \l_scikg_text_tl
    \tl_clear:N \l_scikg_anchor_tl
    \tl_clear:N \l_scikg_page_tl
    \bool_set_true:N \l_scikg_inline_bool
    \bool_set_false:N \l_scikg_has_label_bool
  }

% ============================================================
% Validation
% ============================================================

\cs_new_protected:Npn \scikg_validate_annotation:
  {
    \tl_if_blank:VTF \l_scikg_type_tl
      {
        \scikg_warn_or_error:nn { missing-type }
          { \int_use:N \g_scikg_annotation_int }
      }
      { }

    \tl_if_blank:VTF \l_scikg_id_tl
      {
        \scikg_warn_or_error:nn { missing-id }
          { \int_use:N \g_scikg_annotation_int }
      }
      { }

    \tl_if_blank:VTF \l_scikg_text_tl
      {
        \scikg_warn_or_error:nn { empty-text }
          { \int_use:N \g_scikg_annotation_int }
      }
      { }
  }

% ============================================================
% Labels and references
% ============================================================

\cs_new_protected:Npn \scikg_register_label:
  {
    \bool_if:NT \l_scikg_has_label_bool
      {
        \prop_if_in:NVTF \g_scikg_label_anchor_prop \l_scikg_label_tl
          {
            \scikg_warn_or_error:nn { duplicate-label } { \l_scikg_label_tl }
          }
          {
            \prop_gput:NVV \g_scikg_label_anchor_prop \l_scikg_label_tl \l_scikg_anchor_tl
            \prop_gput:NVV \g_scikg_label_text_prop   \l_scikg_label_tl \l_scikg_text_tl
          }
      }
  }

\NewDocumentCommand \scikgref { m }
  {
    \prop_if_in:NnTF \g_scikg_label_anchor_prop {#1}
      {
        \prop_get:NnN \g_scikg_label_anchor_prop {#1} \l_tmpa_tl
        \prop_get:NnN \g_scikg_label_text_prop   {#1} \l_tmpb_tl
        \hyperlink{\l_tmpa_tl}
          {
            \tl_if_blank:VTF \l_tmpb_tl
              {#1}
              { \l_tmpb_tl }
          }
      }
      {
        \msg_warning:nnn { scikg } { undefined-label } {#1}
        ??
      }
  }

% ============================================================
% Anchors
% ============================================================

\cs_new_protected:Npn \scikg_make_anchor_name:
  {
    \tl_set:Nx \l_scikg_anchor_tl { scikg.\int_use:N \g_scikg_annotation_int }
  }

\cs_new_protected:Npn \scikg_place_anchor:
  {
    \Hy@raisedlink
      {
        \hyper@anchorstart{\l_scikg_anchor_tl}
        \hyper@anchorend
      }
  }

\cs_new_protected:Npn \scikg_maybe_place_anchor:
  {
    \bool_if:NTF \l_scikg_inline_bool
      {
        \bool_if:NT \g_scikg_anchors_bool
          { \scikg_place_anchor: }
      }
      {
        \bool_if:NT \g_scikg_silentanchors_bool
          { \scikg_place_anchor: }
      }
  }

% ============================================================
% Output helpers
% ============================================================

\cs_new:Npn \scikg_mode_value:
  {
    \bool_if:NTF \l_scikg_inline_bool { inline } { silent }
  }

\cs_new_protected:Npn \scikg_capture_page:
  {
    \tl_set:Nx \l_scikg_page_tl { \thepage }
  }

\cs_new_protected:Npn \scikg_prepare_sanitized_fields:
  {
    \scikg_sanitize_to_str:nN { \l_scikg_anchor_tl } \l_scikg_s_anchor_tl
    \scikg_sanitize_to_str:nN { \l_scikg_type_tl }   \l_scikg_s_type_tl
    \scikg_sanitize_to_str:nN { \l_scikg_id_tl }     \l_scikg_s_id_tl
    \scikg_sanitize_to_str:nN { \l_scikg_label_tl }  \l_scikg_s_label_tl
    \scikg_sanitize_to_str:nN { \l_scikg_text_tl }   \l_scikg_s_text_tl
    \scikg_sanitize_to_str:nN { \l_scikg_page_tl }   \l_scikg_s_page_tl
  }

\cs_new_protected:Npn \scikg_write_tsv:
  {
    \scikg_prepare_sanitized_fields:
    \iow_now:Nx \g_scikg_out_iow
      {
        \int_use:N \g_scikg_annotation_int \c_tab_token
        \l_scikg_s_anchor_tl \c_tab_token
        \scikg_mode_value: \c_tab_token
        \l_scikg_s_type_tl \c_tab_token
        \l_scikg_s_id_tl \c_tab_token
        \l_scikg_s_label_tl \c_tab_token
        \l_scikg_s_page_tl \c_tab_token
        \l_scikg_s_text_tl
      }
  }

\cs_new_protected:Npn \scikg_write_jsonl:
  {
    \scikg_prepare_sanitized_fields:
    \iow_now:Nx \g_scikg_out_iow
      {
        \c_left_brace_str
        "n":"\int_use:N \g_scikg_annotation_int",
        "anchor":"\l_scikg_s_anchor_tl",
        "mode":"\scikg_mode_value:",
        "type":"\l_scikg_s_type_tl",
        "id":"\l_scikg_s_id_tl",
        "label":"\l_scikg_s_label_tl",
        "page":"\l_scikg_s_page_tl",
        "text":"\l_scikg_s_text_tl"
        \c_right_brace_str
      }
  }

\cs_new_protected:Npn \scikg_write_annotation:
  {
    \str_if_eq:VnTF \g_scikg_format_tl { jsonl }
      { \scikg_write_jsonl: }
      { \scikg_write_tsv: }
  }

% ============================================================
% Main annotation command
% ============================================================

\NewDocumentCommand \scikgannotate { O{} m }
  {
    \scikg_annotation_reset:
    \keys_set:nn { scikg / ann } {#1}
    \tl_set:Nn \l_scikg_text_tl {#2}
    \int_gincr:N \g_scikg_annotation_int
    \scikg_make_anchor_name:
    \scikg_capture_page:
    \scikg_validate_annotation:
    \scikg_register_label:
    \scikg_maybe_place_anchor:
    \bool_if:NT \l_scikg_inline_bool
      { \l_scikg_text_tl }
    \scikg_write_annotation:
  }

% ============================================================
% Convenience wrappers
% ============================================================

\NewDocumentCommand \scikgsoftware { m m }
  { \scikgannotate[mode=inline,type=software,id={#1}]{#2} }

\NewDocumentCommand \scikgsoftwaresilent { m m }
  { \scikgannotate[mode=silent,type=software,id={#1}]{#2} }

\NewDocumentCommand \scikgperson { m m }
  { \scikgannotate[mode=inline,type=person,id={#1}]{#2} }

\NewDocumentCommand \scikgpersonsilent { m m }
  { \scikgannotate[mode=silent,type=person,id={#1}]{#2} }

\NewDocumentCommand \scikgdataset { m m }
  { \scikgannotate[mode=inline,type=dataset,id={#1}]{#2} }

\NewDocumentCommand \scikgdatasetsilent { m m }
  { \scikgannotate[mode=silent,type=dataset,id={#1}]{#2} }

\NewDocumentCommand \scikgmethod { m m }
  { \scikgannotate[mode=inline,type=method,id={#1}]{#2} }

\NewDocumentCommand \scikgmethodsilent { m m }
  { \scikgannotate[mode=silent,type=method,id={#1}]{#2} }

% ============================================================
% Begin/end document hooks
% ============================================================

\AtBeginDocument
  {
    \hypersetup
      {
        pdftitle    = {\g_scikg_title_tl},
        pdfauthor   = {\g_scikg_author_tl},
        pdfkeywords = {\g_scikg_keywords_tl},
        pdfsubject  = {DOI:~\g_scikg_doi_tl.~License:~\g_scikg_license_tl}
      }

    \str_if_eq:VnTF \g_scikg_format_tl { jsonl }
      {
        \iow_open:Nn \g_scikg_out_iow { \jobname.scikg.jsonl }
      }
      {
        \iow_open:Nn \g_scikg_out_iow { \jobname.scikg.tsv }
        \iow_now:Nn \g_scikg_out_iow { n^^Ianchor^^Imode^^Itype^^Iid^^Ilabel^^Ipage^^Itext }
      }
  }

\AtEndDocument
  {
    \iow_close:N \g_scikg_out_iow
  }

\ExplSyntaxOff
\endinput